  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "sans-serif"
      },
      {
        "type": "range",
        "id": "font_heading_scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Heading Scale Size",
        "default": 115
      },
      {
        "type": "select",
        "id": "font_heading_weight",
        "label": "Heading Font Weight",
        "options": [
          { "value": "500", "label": "Medium" },
          { "value": "600", "label": "Semi-Bold" },
          { "value": "700", "label": "Bold" },
          { "value": "800", "label": "Extra-Bold" }
        ],
        "default": "700"
      },
      {
        "type": "header",
        "content": "Body Text"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "sans-serif"
      },
      {
        "type": "range",
        "id": "font_body_scale",
        "min": 90,
        "max": 115,
        "step": 5,
        "unit": "%",
        "label": "Body Scale Size",
        "default": 100
      },
      {
        "type": "select",
        "id": "font_body_weight",
        "label": "Body Font Weight",
        "options": [
          { "value": "300", "label": "Light" },
          { "value": "400", "label": "Normal" },
          { "value": "500", "label": "Medium" }
        ],
        "default": "400"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "header",
        "content": "Global Container Layout"
      },
      {
        "type": "range",
        "id": "container_max_width",
        "min": 1000,
        "max": 1600,
        "step": 40,
        "unit": "px",
        "label": "Maximum Grid Width",
        "default": 1280
      },
      {
        "type": "range",
        "id": "section_spacing_desktop",
        "min": 20,
        "max": 120,
        "step": 10,
        "unit": "px",
        "label": "Section Spacing (Desktop)",
        "default": 80
      },
      {
        "type": "range",
        "id": "section_spacing_mobile",
        "min": 10,
        "max": 80,
        "step": 10,
        "unit": "px",
        "label": "Section Spacing (Mobile)",
        "default": 40
      },
      {
        "type": "header",
        "content": "Cards & Borders"
      },
      {
        "type": "range",
        "id": "card_radius",
        "min": 0,
        "max": 32,
        "step": 2,
        "unit": "px",
        "label": "Card Border Radius",
        "default": 16
      },
      {
        "type": "select",
        "id": "card_shadow",
        "label": "Card Shadow Intensity",
        "options": [
          { "value": "none", "label": "None" },
          { "value": "soft", "label": "Luxury Soft (Subtle)" },
          { "value": "medium", "label": "Medium Depth" },
          { "value": "glass", "label": "Glassmorphism Glow" }
        ],
        "default": "soft"
      },
      {
        "type": "range",
        "id": "global_border_radius",
        "min": 0,
        "max": 24,
        "step": 2,
        "unit": "px",
        "label": "Global Border Radius",
        "default": 8
      }
    ]
  },
