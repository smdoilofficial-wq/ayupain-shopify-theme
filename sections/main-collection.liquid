{%- comment -%}
  Premium Collection Grid Layout Section
{%- endcomment -%}

<div class="collection-header-banner">
  <div class="container">
    <h1 class="section-title">{{ collection.title | default: 'Ayurvedic Relief Catalog' }}</h1>
    <p class="section-subtitle">{{ collection.description | default: 'Pure botanical relief solutions curated to restore complete movement and joint comfort.' }}</p>
  </div>
</div>

<section id="collection" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="container collection-layout">
    
    <!-- 1. Left Sidebar: Advanced Filters -->
    <aside class="collection-sidebar-filters">
      <!-- Filter Group: Availability -->
      <div class="filter-group">
        <h3 class="filter-title">Availability</h3>
        <ul class="filter-list">
          <li>
            <label class="filter-item-label">
              <input type="checkbox" checked>
              <span>In Stock (3)</span>
            </label>
          </li>
          <li>
            <label class="filter-item-label">
              <input type="checkbox">
              <span>Out of Stock (0)</span>
            </label>
          </li>
        </ul>
      </div>

      <!-- Filter Group: Category Type -->
      <div class="filter-group">
        <h3 class="filter-title">Therapy Type</h3>
        <ul class="filter-list">
          <li>
            <label class="filter-item-label">
              <input type="checkbox" checked>
              <span>Ayurvedic Oil (2)</span>
            </label>
          </li>
          <li>
            <label class="filter-item-label">
              <input type="checkbox">
              <span>Therapy Massager (1)</span>
            </label>
          </li>
        </ul>
      </div>
    </aside>

    <!-- 2. Right Side: Products Panel -->
    <div class="collection-grid-wrapper">
      
      <!-- Top header filters / sorting summary -->
      <div class="collection-grid-header">
        <span>Showing 3 Products</span>
        <div class="sorting-row">
          <label for="SortBy" style="font-weight: 700; font-size: 0.88rem; margin-right: 8px;">Sort by:</label>
          <select id="SortBy" style="padding: 6px 12px; border-radius: 4px; border: 1px solid rgba(15, 118, 110, 0.2); font-family: var(--font-body); font-size: 0.88rem;">
            <option>Featured</option>
            <option selected>Best Selling</option>
            <option>Price: Low to High</option>
            <option>Price: High to Low</option>
          </select>
        </div>
      </div>

      <!-- Products Grid -->
      <div class="collection-grid-products">
        {%- for product in collection.products -%}
          {%- render 'product-card', product: product -%}
        {%- else -%}
          <p class="collection-empty" style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--color-text-muted);">No products found in this collection.</p>
        {%- endfor -%}
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Collection Settings",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ]
}
{% endschema %}
