{%- comment -%}
  Premium Sticky Header Component with Dynamic Customizer Mega-menu Support
{%- endcomment -%}

<div class="site-header-wrapper">
  <header class="site-header" role="banner" style="background-color: {{ section.settings.header_bg_color }}">
    <div class="container header-container">
      
      <!-- Mobile Hamburger Navigation (Left on Mobile) -->
      <button class="mobile-menu-btn header-icon" aria-label="Menu" type="button">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <!-- Brand Logo (Center or Left) -->
      <a href="{{ routes.root_url }}" class="logo-link">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 140 }}" alt="{{ shop.name }}" style="max-width: {{ section.settings.logo_width }}px;">
        {%- else -%}
          <span>AYUPAIN</span><span class="logo-dot"></span>
        {%- endif -%}
      </a>

      <!-- Main Navigation Menu (Desktop Only) -->
      <nav class="desktop-navigation" role="navigation">
        <ul class="main-nav">
          {%- for link in linklists[section.settings.menu].links -%}
            <li>
              <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}">
                {{ link.title }}
              </a>
            </li>
          {%- else -%}
            <!-- Fallback Static Menu Items for Preview -->
            <li><a href="/" class="nav-link active">Home</a></li>
            <li><a href="#product" class="nav-link">Shop Relief</a></li>
            <li><a href="#conditions" class="nav-link">Pain Conditions</a></li>
            <li><a href="#why-us" class="nav-link">Why Ayurveda</a></li>
            <li><a href="#faqs" class="nav-link">FAQ</a></li>
          {%- endfor -%}
        </ul>
      </nav>

      <!-- Action Icons (Right Panel) -->
      <div class="header-icons">
        <!-- Search Trigger -->
        <a href="{{ routes.search_url }}" class="header-icon" aria-label="Search">
          <svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </a>

        <!-- Account Link -->
        <a href="{{ routes.account_url }}" class="header-icon" aria-label="Account">
          <svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>

        <!-- WhatsApp Quick Chat support -->
        {%- if settings.whatsapp_number != blank -%}
          {%- assign encoded_msg = settings.whatsapp_message | url_encode -%}
          <a href="https://wa.me/{{ settings.whatsapp_number }}?text={{ encoded_msg }}" target="_blank" class="header-icon" aria-label="WhatsApp Support" style="color: #25D366;">
            <svg class="icon-svg" style="fill: currentColor; stroke: none;" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.49 1.988 14.032.96 11.458.96 6.02 1.02 1.598 5.39 1.593 10.819c-.001 1.745.474 3.447 1.378 4.962L2.01 20.825l5.228-1.376c-.23.11-.42.21-.59.305zM17.43 14.93c-.31-.15-1.84-.87-2.12-.97-.29-.1-.5-.15-.71.15-.22.3-.83.97-1.02 1.18-.19.2-.39.23-.7.08-.31-.15-1.32-.47-2.52-1.51-.93-.81-1.56-1.82-1.74-2.12-.19-.3-.02-.47.13-.62.14-.14.31-.35.47-.53.16-.17.21-.3.32-.49.1-.2.05-.37-.02-.52-.07-.15-.71-1.63-.97-2.24-.26-.59-.52-.51-.71-.52-.18-.01-.39-.01-.6-.01-.2 0-.53.07-.81.37-.28.3-1.07 1.01-1.07 2.47 0 1.46 1.09 2.87 1.24 3.07.15.2 2.14 3.16 5.19 4.41.72.3 1.29.48 1.73.61.73.22 1.39.19 1.92.11.59-.08 1.84-.72 2.1-1.39.26-.66.26-1.22.18-1.34-.07-.1-.28-.15-.59-.3z"/>
            </svg>
          </a>
        {%- endif -%}

        <!-- Sticky Cart Icon (Opens drawer panel) -->
        <a href="/cart" class="header-icon js-open-cart" aria-label="Cart">
          <svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
          <span class="cart-count-badge" style="display: none;">0</span>
        </a>
      </div>
      
    </div>
  </header>
</div>

{% schema %}
{
  "name": "Header Settings",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Brand Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Logo Max Width",
      "default": 130
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Navigation Menu",
      "default": "main-menu"
    },
    {
      "type": "color",
      "id": "header_bg_color",
      "label": "Header Background Color",
      "default": "#FFFFFF"
    }
  ]
}
{% endschema %}
