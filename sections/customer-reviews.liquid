      "max": 100,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "star_2_percentage",
      "label": "2/1 Star Percentage",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Customer Review",
      "settings": [
        {
          "type": "text",
          "id": "author_name",
          "label": "Customer Name",
          "default": "Gopalakrishnan S."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified Buyer Badge",
          "default": true
        },
        {
          "type": "text",
          "id": "date",
          "label": "Review Date",
          "default": "June 18, 2026"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating (1-5)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review Title",
          "default": "Incredible relief for my knee osteoarthritis!"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Review Body Text",
          "default": "I was skeptical about trying another pain oil since I tried almost everything available in pharmacies. But AYUPAIN™ actually has some warmth that penetrates into the knee immediately. In just one week of applying, my walking distance has improved without using my knee support brace. Will definitely buy the double pack next time."
        },
        {
          "type": "image_picker",
          "id": "review_image",
          "label": "Review Image"
        }
      ]
    }
  ],
  "presets": [
