{%- if section.settings.show_announcement -%}
  <div class="announcement-bar" style="background-color: {{ section.settings.color_bg }}; color: {{ section.settings.color_text }};">
    <div class="container">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" style="color: inherit;">
          {{ section.settings.text | escape }}
        </a>
      {%- else -%}
        {{ section.settings.text | escape }}
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "🎉 Special Launch Offer: Get 10% OFF + FREE Shipping & Cash on Delivery across India! 🇮🇳"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link Target (Optional)"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background Color",
      "default": "#0F766E"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text Color",
      "default": "#FFFFFF"
    }
  ]
}
{% endschema %}
