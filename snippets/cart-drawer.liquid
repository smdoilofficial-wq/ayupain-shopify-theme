{%- comment -%}
  Premium Cart Drawer Component
{%- endcomment -%}

<div id="CartDrawerOverlay" class="cart-drawer-overlay">
  <div class="cart-drawer" role="dialog" aria-modal="true" aria-labelledby="CartDrawerTitle">
    
    <!-- Drawer Header -->
    <div class="cart-drawer-header">
      <h2 id="CartDrawerTitle" class="cart-drawer-title">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span>{{ 'general.cart.title' | t | default: 'Your Cart' }}</span>
        <span class="cart-count-badge" style="position: static; margin-left: 6px; display: none;">0</span>
      </h2>
      <button type="button" class="cart-drawer-close-btn js-close-cart" aria-label="Close cart">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Free Shipping Goal Tracker -->
    <div class="cart-shipping-goal-wrapper">
      <div id="CartShippingGoalText" class="cart-shipping-goal-text">
        Add only <strong>₹999</strong> more for FREE Shipping!
      </div>
      <div class="cart-shipping-bar-bg">
        <div id="CartShippingBarFill" class="cart-shipping-bar-fill"></div>
      </div>
    </div>

    <!-- Scrollable Drawer Body -->
    <div id="CartDrawerBody" class="cart-drawer-body">
      <!-- Dynamic list loaded via theme.js -->
      <div class="cart-empty-message">
        <svg class="cart-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <p>{{ 'general.cart.empty' | t | default: 'Your cart is empty. Add AYUPAIN™ to begin your relief journey!' }}</p>
      </div>
    </div>

    <!-- Checkout Footer -->
    <div class="cart-drawer-footer">
      <div class="cart-subtotal-row">
        <span>{{ 'general.cart.subtotal' | t | default: 'Subtotal' }}</span>
        <span id="CartSubtotalPrice" class="cart-subtotal-price">₹0</span>
      </div>
      <div class="cart-drawer-footer-actions">
        <button type="button" class="btn btn-secondary btn-pulse">
          {{ 'general.cart.buy_now' | t | default: 'Order Now (COD Available)' }}
        </button>
        <button type="button" class="btn btn-outline" style="border-color: #25D366; color: #25D366; display: flex; gap: 8px; justify-content: center; align-items: center;">
          <svg class="icon-svg" style="width: 18px; height: 18px; fill: currentColor; stroke: none;" viewBox="0 0 24 24">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.49 1.988 14.032.96 11.458.96 6.02 1.02 1.598 5.39 1.593 10.819c-.001 1.745.474 3.447 1.378 4.962L2.01 20.825l5.228-1.376c-.23.11-.42.21-.59.305zM17.43 14.93c-.31-.15-1.84-.87-2.12-.97-.29-.1-.5-.15-.71.15-.22.3-.83.97-1.02 1.18-.19.2-.39.23-.7.08-.31-.15-1.32-.47-2.52-1.51-.93-.81-1.56-1.82-1.74-2.12-.19-.3-.02-.47.13-.62.14-.14.31-.35.47-.53.16-.17.21-.3.32-.49.1-.2.05-.37-.02-.52-.07-.15-.71-1.63-.97-2.24-.26-.59-.52-.51-.71-.52-.18-.01-.39-.01-.6-.01-.2 0-.53.07-.81.37-.28.3-1.07 1.01-1.07 2.47 0 1.46 1.09 2.87 1.24 3.07.15.2 2.14 3.16 5.19 4.41.72.3 1.29.48 1.73.61.73.22 1.39.19 1.92.11.59-.08 1.84-.72 2.1-1.39.26-.66.26-1.22.18-1.34-.07-.1-.28-.15-.59-.3z"/>
          </svg>
          <span>{{ 'general.cart.whatsapp_order' | t | default: 'Order via WhatsApp' }}</span>
        </button>
      </div>
      <div class="cart-badge-row-small">
        <span>✓ Free Delivery</span>
        <span>✓ Pay Cash on Delivery</span>
      </div>
    </div>

  </div>
</div>
